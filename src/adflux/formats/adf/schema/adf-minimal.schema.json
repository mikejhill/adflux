{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://adflux.local/schema/adf-minimal.json",
  "title": "ADF (minimal structural schema)",
  "description": "Minimum viable validator for ADF: enforces the doc root shape and the recursive node-with-type structure. Not a full per-node-type schema.",
  "type": "object",
  "required": ["type", "version", "content"],
  "properties": {
    "type": { "const": "doc" },
    "version": { "type": "integer", "minimum": 1 },
    "content": {
      "type": "array",
      "items": { "$ref": "#/$defs/node" }
    }
  },
  "$defs": {
    "node": {
      "type": "object",
      "required": ["type"],
      "properties": {
        "type": { "type": "string", "minLength": 1 },
        "attrs": { "type": "object" },
        "marks": {
          "type": "array",
          "items": { "$ref": "#/$defs/mark" }
        },
        "content": {
          "type": "array",
          "items": { "$ref": "#/$defs/node" }
        },
        "text": { "type": "string" }
      },
      "additionalProperties": false
    },
    "mark": {
      "type": "object",
      "required": ["type"],
      "properties": {
        "type": { "type": "string", "minLength": 1 },
        "attrs": { "type": "object" }
      },
      "additionalProperties": false
    }
  }
}
