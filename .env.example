# adflux E2E tests — environment template.
#
# Copy this file to `.env` at the project root and fill in real values.
# `.env` is gitignored and must never be committed.
#
# All variables consumed by the E2E suite are prefixed `ADFLUX_E2E_` so
# they are clearly delineated from any other tooling that may reach into
# the shell environment for Atlassian credentials.
#
# In CI these variables are populated from GitHub Actions secrets on the
# `e2e` environment — see `.github/workflows/e2e.yml`.
#
# These tests hit a live Atlassian Cloud tenant. They CREATE Confluence
# pages and Jira issues, GET them, then DELETE pages / CLOSE issues. They
# are skipped if any required value is missing or the credentials cannot
# authenticate.

# --- Atlassian tenant + auth (used by both Confluence and Jira) -------------

# Atlassian Cloud site hostname (no scheme, no path).
ADFLUX_E2E_ATLASSIAN_SITE=your-tenant.atlassian.net

# Atlassian account email — paired with the API token via HTTP Basic auth.
ADFLUX_E2E_ATLASSIAN_EMAIL=you@example.com

# API token from https://id.atlassian.com/manage-profile/security/api-tokens
# (single token works for both Confluence and Jira REST APIs)
ADFLUX_E2E_ATLASSIAN_API_TOKEN=ATATT3xFf...

# --- Confluence-specific ----------------------------------------------------

# Space to create test pages in. Either supply the numeric id directly
# (ADFLUX_E2E_CONFLUENCE_SPACE_ID) or the space key
# (ADFLUX_E2E_CONFLUENCE_SPACE_KEY) and the tests will resolve it.
ADFLUX_E2E_CONFLUENCE_SPACE_KEY=YOUR_SPACE_KEY
# ADFLUX_E2E_CONFLUENCE_SPACE_ID=131196

# Optional: nest E2E pages under an existing parent page (otherwise
# adflux creates an ephemeral parent for each test run and deletes it
# afterwards unless ADFLUX_E2E_KEEP_PAGES=true).
# ADFLUX_E2E_CONFLUENCE_PARENT_PAGE_ID=

# --- Jira-specific ----------------------------------------------------------

# Optional: enable the Jira E2E suite by setting a project key. Issues
# are *closed* on teardown (transitioned to Done/Closed), never deleted.
# ADFLUX_E2E_JIRA_PROJECT_KEY=YOUR_PROJECT_KEY

# --- Behavior ---------------------------------------------------------------

# If true, leave created pages on the server for manual inspection.
# Default false: every test deletes the page it created.
ADFLUX_E2E_KEEP_PAGES=false
